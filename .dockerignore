.DS_Store
Thumbs.db
*.log
*.tsbuildinfo
**/*.tsbuildinfo

# Docs / dev tooling (not needed inside image)
*.md
vendor/
.cursor/
.cursor-plugin/
coverage/
playwright-report/
test-results/
