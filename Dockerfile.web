# ─── Stage 1: Build ───────────────────────────────────────────────────────────
FROM node:20-slim AS builder

RUN npm install -g pnpm@9

WORKDIR /repo

# Copy workspace manifests first for better layer caching on repeated builds
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/shared/package.json ./packages/shared/
COPY apps/web/package.json ./apps/web/
COPY apps/crawler/package.json ./apps/crawler/

RUN pnpm install --frozen-lockfile

# Copy full source (node_modules excluded via .dockerignore)
COPY . .

# Build shared package (required by web)
RUN pnpm --filter @privacy-diff/shared build

# Dummy build-time values so Next.js page-data collection passes Zod validation
# in env.ts. Real values are injected by Railway at runtime.
ARG DATABASE_URL=http://placeholder.invalid
ARG CRAWLER_URL=http://placeholder.invalid
ARG CRAWLER_SHARED_SECRET=build-placeholder
ARG PUBLIC_BASE_URL=http://placeholder.invalid
ARG NODE_ENV=production
ENV DATABASE_URL=$DATABASE_URL
ENV CRAWLER_URL=$CRAWLER_URL
ENV CRAWLER_SHARED_SECRET=$CRAWLER_SHARED_SECRET
ENV PUBLIC_BASE_URL=$PUBLIC_BASE_URL
ENV NODE_ENV=$NODE_ENV

# Build Next.js with standalone output
RUN pnpm --filter @privacy-diff/web build

# Compile migrate.ts to CommonJS
RUN cd apps/web && npx tsc -p tsconfig.migrate.json

# Assemble a minimal node_modules for the migrate script (drizzle-orm + postgres)
# These are production deps of @privacy-diff/web but Next.js standalone tracing
# may not include the migrator subpath since the app itself doesn't import it.
RUN mkdir -p /migrate-deps/node_modules \
    && cp -rL apps/web/node_modules/drizzle-orm /migrate-deps/node_modules/ \
    && cp -rL apps/web/node_modules/postgres /migrate-deps/node_modules/

# ─── Stage 2: Runtime ─────────────────────────────────────────────────────────
FROM node:20-alpine AS runtime

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Next.js standalone output — self-contained server with all production deps
COPY --from=builder /repo/apps/web/.next/standalone ./

# Static assets and public dir are NOT included in standalone by default.
# Must go under apps/web/ to match the monorepo layout that outputFileTracingRoot produces.
COPY --from=builder /repo/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /repo/apps/web/public ./apps/web/public

# Migration script (compiled to CJS) + its deps + SQL migration files
COPY --from=builder /repo/dist-migrate/migrate.js ./migrate.js
COPY --from=builder /migrate-deps/node_modules ./migrate-deps/
COPY --from=builder /repo/apps/web/src/db/migrations ./migrations

EXPOSE 3000

# Run migrations (NODE_PATH points to migrate deps) then start Next.js
# server.js is at apps/web/ because outputFileTracingRoot preserves monorepo layout
CMD ["sh", "-c", "NODE_PATH=/app/migrate-deps node migrate.js && node apps/web/server.js"]
