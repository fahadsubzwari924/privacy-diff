{
  "name": "@privacy-diff/crawler",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "files": ["dist"],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "build:trackers": "tsx scripts/build-tracker-map.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@privacy-diff/shared": "workspace:*",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pino": "^9.2.0",
    "playwright": "^1.44.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vitest": "^4.1.4"
  }
}
